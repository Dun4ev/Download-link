TELEGRAM_BOT_TOKEN=123456:replace_me

# Inside Docker this path is mapped to ./data/downloads on the NAS.
DOWNLOAD_DIR=/data/downloads

# Optional: send downloaded files to another chat/channel.
# Leave empty to reply with the file in the same bot chat where you sent the link.
SEND_TO_CHAT_ID=

# Optional: cookies exported from your browser in Netscape format.
# Often needed for Instagram, Facebook, X/Twitter and age/login-restricted posts.
YTDLP_COOKIES_FILE=/data/cookies/cookies.txt

# Telegram Bot API upload limit depends on account/API path. Keep this conservative.
TELEGRAM_MAX_UPLOAD_MB=50
